{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bilet",
  "version": "1.1.0",
  "identifier": "com.bilet.app",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/bilet/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "bilet",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Habeeb-Rahman-CA/bilet/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyMDQ4OUQ1MzU5MDc4MUIKUldRYmVKQTExWWtFb3RVTHZyM3JHSWM0M2QzaXdSa0FuNmRIVnJOeTNmbFY2U0tBcldqY2ZHdG4K"
    }
  }
}